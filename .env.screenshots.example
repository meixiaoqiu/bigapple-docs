# 截图环境变量示例（不含真实值）
# 复制为 .env.screenshots 后填入实际凭据
# .env.screenshots 已被 .gitignore 忽略，不会提交到 Git

# 公开页面、成员页面和治理页面的入口
SCREENSHOT_BASE_URL=

# Django Admin 和 Simulation Lab 的入口
# 可以与 SCREENSHOT_BASE_URL 相同
SCREENSHOT_ADMIN_BASE_URL=

# 普通成员账号——使用 Live OS 中已有的本地测试账号
DOCS_SCREENSHOT_MEMBER_LOGIN=
DOCS_SCREENSHOT_MEMBER_PASSWORD=

# 治理成员账号——使用 Live OS 中已有的本地治理账号
DOCS_SCREENSHOT_GOVERNANCE_LOGIN=
DOCS_SCREENSHOT_GOVERNANCE_PASSWORD=

# 超级管理员账号——使用 Live OS 中已有的管理账号
DOCS_SCREENSHOT_SUPERUSER_LOGIN=
DOCS_SCREENSHOT_SUPERUSER_PASSWORD=

# 可选：指定本机浏览器
# PLAYWRIGHT_EXECUTABLE_PATH=
